{
  "name": "@posthook/node",
  "version": "1.0.0",
  "description": "Official Posthook TypeScript SDK for scheduling and managing webhooks",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "posthook",
    "webhook",
    "webhooks",
    "scheduled-webhooks",
    "api",
    "sdk"
  ],
  "author": "Posthook",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/posthook/posthook-node.git"
  },
  "homepage": "https://posthook.io",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
